RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_CONNECTOR_PER_MINUTE=30
RATE_LIMIT_MUTATING_PER_MINUTE=120
RATE_LIMIT_READ_PER_MINUTE=600

PRODUCT_NAME=CrewAI Enterprise Pipeline
