PROJECT_NAME=CrewAI Enterprise Pipeline
APP_ENV=development
APP_VERSION=0.1.0
AUTO_CREATE_SCHEMA=true
DEFAULT_COUNTRY=India
REQUEST_ID_HEADER_NAME=X-Request-ID
